<% vpn_services = services.select { |s| s.use_vpn? && s.port } %><% vpn_services.each do |svc| %>:<%= svc.port %> {
  reverse_proxy wireguard:<%= svc.port %>
}
<% end %>

# Vaultwarden reverse proxy with HTTPS
fatlaptop.hippogriff-stonecat.ts.net:8000 {
  tls /etc/caddy/certs/fatlaptop.hippogriff-stonecat.ts.net.crt /etc/caddy/certs/fatlaptop.hippogriff-stonecat.ts.net.key

  # Main API and web vault
  reverse_proxy vaultwarden:80 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-Host {host}
  }
}
