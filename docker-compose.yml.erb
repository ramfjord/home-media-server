<% services_config = services.select(&:dockerized?).map do |svc|
  service_config = {
    "container_name" => svc.name,
    "environment" => ["TZ=Etc/UTC"],
  }

  # Only set user if user_id is not nil (wireguard runs as root)
  service_config["user"] = svc.user_id if svc.user_id

  # Handle VPN routing
  if svc.use_vpn?
    service_config["network_mode"] = "service:wireguard"
    service_config["depends_on"] = {
      "wireguard" => {
        "condition" => "service_healthy"
      }
    }
  else
    # Only add networks if network_mode is not specified (they're mutually exclusive)
    service_config["networks"] = ["mediaserver"]

    if svc.port && !svc.docker_config.key?("ports")
      service_config["ports"] = ["#{svc.port}:#{svc.port}"]
    end
  end

  service_config = service_config.merge(svc.docker_config)

  # Add groups as group_add if specified
  if svc.group_ids.any?
    service_config["group_add"] = svc.group_ids.map(&:to_i)
  end

  [svc.name, service_config]
end.to_h %>
<%= {
  "networks" => {
    "mediaserver" => { "driver" => "bridge" }
  },
  "services" => services_config
}.to_yaml %>
