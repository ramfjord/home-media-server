networks:
  mediaserver:
    driver: bridge

services:
  wireguard:
    image: <%= vpn_gateway["image"] %>
    container_name: wireguard
    networks:
      - mediaserver
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Etc/UTC
    sysctls:
      net.ipv4.conf.all.src_valid_mark: 1
    volumes:
% vpn_gateway["volumes"].each do |vol|
      - <%= vol %>
% end
    ports:
% vpn_services.each do |svc|
      - "<%= svc["port"] %>:<%= svc["port"] %>"
% end
    healthcheck:
      test: ping -c 1 1.1.1.1 || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    restart: unless-stopped

% services.select { |s| s["dockerized"] }.each do |svc|
  <%= svc["name"] %>:
    image: <%= svc["image"] %>
    container_name: <%= svc["name"] %>
% if svc["uses_vpn"]
    network_mode: "service:wireguard"
% end
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Etc/UTC
    volumes:
%   svc["volumes"].each do |vol|
      - <%= vol %>
%   end
    depends_on:
      wireguard:
        condition: service_healthy
    restart: unless-stopped

% end
