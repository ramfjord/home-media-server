<% services_config = services.select(&:dockerized?).map do |svc|
  service_config = {
    "container_name" => svc.name,
    "environment" => ["PUID=1000", "PGID=1000", "TZ=Etc/UTC"]
  }

  service_config["networks"] = ["mediaserver"]

  if svc.port && !svc.docker_config.key?("ports")
    service_config["ports"] = ["#{svc.port}:#{svc.port}"]
  end

  service_config = service_config.merge(svc.docker_config)

  service_config["user"] = svc.uid.to_s if svc.uid

  [svc.name, service_config]
end.to_h %>
<%= {
  "networks" => {
    "mediaserver" => { "driver" => "bridge" }
  },
  "services" => services_config
}.to_yaml %>
