global:
  scrape_interval: <%= config_yaml["fx_scrape_interval"] || "30s" %>
  external_labels:
    deployment: <%= config_yaml["fx_label"] || "fallback" %>
    host: <%= hostname %>

scrape_configs:
<% services.select { |s| s.port && s.healthz }.each do |svc| %>
  - job_name: "<%= svc.name %>"
    metrics_path: <%= svc.healthz %>
    static_configs:
      - targets: ["<%= svc.name %>:<%= svc.port %>"]
        labels:
          partof: <%= svc.partof %>
<% end %>
