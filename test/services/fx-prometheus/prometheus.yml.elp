global:
  scrape_interval: <%= (or (getf globals :fx-scrape-interval) "30s") %>
  external_labels:
    deployment: <%= (or fx_label "fallback") %>
    host: <%= hostname %>

scrape_configs:
<%- (loopservices (services :where (and port healthz)) -%>
  - job_name: "<%= name %>"
    metrics_path: <%= healthz %>
    static_configs:
      - targets: ["<%= name %>:<%= port %>"]
        labels:
          partof: <%= partof %>
<%- ) -%>
