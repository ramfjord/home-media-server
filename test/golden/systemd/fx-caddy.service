[Unit]
Description=Fixture reverse proxy (overridden) (fx-caddy)
After=docker.service mediaserver-network.service
Requires=docker.service mediaserver-network.service
PartOf=mediaserver-network.service mediaserver.target

[Service]
Type=simple
TimeoutStartSec=0
Restart=on-failure
RestartSec=10
ExecStart=/usr/bin/docker compose -f /opt/fx-mediaserver/config/fx-caddy/docker-compose.yml up fx-caddy
ExecStop=/usr/bin/docker compose -f /opt/fx-mediaserver/config/fx-caddy/docker-compose.yml stop fx-caddy
ExecReload=/usr/bin/docker compose -f /opt/fx-mediaserver/config/fx-caddy/docker-compose.yml kill --signal SIGHUP fx-caddy

[Install]
WantedBy=mediaserver.target
