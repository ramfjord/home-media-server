#!/bin/bash
# Rendered from checks/otelcol.sh.elp. DO NOT edit this file directly.
set -euo pipefail
<%- (loopservices (services :where (string= name "otelcol")) -%>
docker run --rm \
  -v "$PWD/config/otelcol:/etc/otelcol:ro" \
  <%= (getf docker_config :image) %> \
  validate --config=/etc/otelcol/otelcol-config.yaml
<%- ) -%>
