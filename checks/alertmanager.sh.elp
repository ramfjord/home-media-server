#!/bin/bash
# Rendered from checks/alertmanager.sh.elp. DO NOT edit this file directly.
set -euo pipefail
<%- (loopservices (services :where (string= name "alertmanager")) -%>
docker run --rm \
  -v "$PWD/config/alertmanager:/etc/alertmanager:ro" \
  --entrypoint /bin/amtool \
  <%= (getf docker_config :image) %> \
  check-config /etc/alertmanager/alertmanager.yml
<%- ) -%>
