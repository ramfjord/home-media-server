#!/bin/bash
# Rendered from checks/compose.sh.elp. DO NOT edit this file directly.
#
# One docker-compose template fans out to N per-service compose files.
# Validate each non-empty render with `compose config`.
set -euo pipefail
fail=0
for f in config/*/docker-compose.yml; do
  [ -s "$f" ] || continue
  docker compose -f "$f" config > /dev/null || { echo "FAIL: $f"; fail=1; }
done
exit $fail
