#!/bin/bash
# Rendered from checks/compose.sh.elp. DO NOT edit this file directly.
#
# One docker-compose template fans out to N per-service compose files,
# all listed in the manifest below. Validate each with `compose config`.
set -euo pipefail
manifest="config/mediaserver/docker-compose.yml.manifest"
fail=0
while read -r f; do
  [ -z "$f" ] && continue
  docker compose -f "config/$f" config > /dev/null || { echo "FAIL: $f"; fail=1; }
done < "$manifest"
exit $fail
