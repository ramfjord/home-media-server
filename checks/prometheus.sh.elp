#!/bin/bash
# Rendered from checks/prometheus.sh.elp. DO NOT edit this file directly.
set -euo pipefail
<%- (loopservices (services :where (string= name "prometheus")) -%>
docker run --rm \
  -v "$PWD/config/prometheus:/etc/prometheus:ro" \
  --entrypoint /bin/promtool \
  <%= (getf docker_config :image) %> \
  check config /etc/prometheus/prometheus.yml
<%- ) -%>
