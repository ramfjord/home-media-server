#!/bin/bash
# Run with sudo for first-time setup. Safe to call without sudo after users exist.

INSTALL_BASE="<%= install_base %>"

groupadd --force mediaserver 2>/dev/null || true

SERVICES=(
<% services.select(&:dockerized?).each do |svc| %>
  "<%= svc.name %>:<%= svc.docker_config['user'] || '' %>"
<% end %>
)

for entry in "${SERVICES[@]}"; do
  name="${entry%%:*}"
  uid="${entry##*:}"
  if ! id -u "$name" > /dev/null 2>&1; then
    uid_arg=""
    [[ -n "$uid" ]] && uid_arg="--uid $uid"
    useradd --system $uid_arg --no-create-home --shell /sbin/nologin "$name" 2>/dev/null || true
    usermod -aG mediaserver "$name" 2>/dev/null || true
  fi
  mkdir -p "$INSTALL_BASE/config/$name" 2>/dev/null || true
  chown "$name:mediaserver" "$INSTALL_BASE/config/$name" 2>/dev/null || true
  chmod 775 "$INSTALL_BASE/config/$name" 2>/dev/null || true
done
