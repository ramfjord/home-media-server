<% service_config = {
  "container_name" => service.name,
  "environment" => ["TZ=Etc/UTC"],
}

service_config["user"] = service.user_id if service.user_id

if service.use_vpn?
  # Share wireguard's network namespace. Cross-compose-project safe
  # because docker resolves container:<name> at runtime.
  service_config["network_mode"] = "container:wireguard"
else
  service_config["networks"] = ["mediaserver"]
  if service.port && !service.docker_config.key?("ports")
    service_config["ports"] = ["#{service.port}:#{service.port}"]
  end
end

service_config = service_config.merge(service.docker_config)

if service.group_ids.any?
  service_config["group_add"] = service.group_ids.map(&:to_i)
end

compose = { "services" => { service.name => service_config } }
unless service.use_vpn?
  compose["networks"] = { "mediaserver" => { "external" => true, "name" => "mediaserver" } }
end
%>
<%= compose.to_yaml %>
