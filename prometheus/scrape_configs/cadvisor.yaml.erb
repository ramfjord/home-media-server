scrape_configs:
  - job_name: cadvisor
    static_configs:
      - targets: ["cadvisor:8080"]
        labels:
          exporter: cadvisor
    metric_relabel_configs:
      <% services.select(&:dockerized?).each do |svc| %>
      - source_labels: [name]
        target_label: service
        replacement: <%= svc.name %>
        regex: "<%= svc.name %>"
      - source_labels: [name]
        target_label: partof
        replacement: <%= svc.partof %>
        regex: "<%= svc.name %>"
      <% end %>
