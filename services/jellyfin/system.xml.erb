<?xml version="1.0" encoding="utf-8"?>
<ServerConfiguration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <LogFileRetentionDays>3</LogFileRetentionDays>
  <IsStartupWizardCompleted>true</IsStartupWizardCompleted>
  <CachePath>${install_base}/config/cache</CachePath>
  <MetadataPath>${install_base}/config/metadata</MetadataPath>
  <ContentPath>${install_base}/config/media</ContentPath>
  <LogPath>${install_base}/config/logs</LogPath>
  <InternalMetadataPath>${install_base}/config/metadata/internal</InternalMetadataPath>
  <VirtualInterfaceNames>
    <VirtualInterfaceName>eth0</VirtualInterfaceName>
  </VirtualInterfaceNames>
  <EnableMetrics>false</EnableMetrics>
  <EnableNormalizedItemByNameIds>true</EnableNormalizedItemByNameIds>
  <PublicPort>8096</PublicPort>
  <PublicHttpsPort>8920</PublicHttpsPort>
  <HttpsBindAddress>::</HttpsBindAddress>
  <HttpBindAddress>::</HttpBindAddress>
  <EnableHttpServer>true</EnableHttpServer>
  <EnableHttpsServer>false</EnableHttpsServer>
  <BaseUrl>/</BaseUrl>
  <PublishedServerUrl>http://${hostname}:8096</PublishedServerUrl>
  <UPnPCreateDebugLog>false</UPnPCreateDebugLog>
  <UPnPEnableServer>true</UPnPEnableServer>
  <UPnPEnableBroadcast>true</UPnPEnableBroadcast>
  <UDPPortRange />
  <UPnPEnableInteriority>true</UPnPEnableInteriority>
  <CollectionType />
  <AutoRunWebApp>true</AutoRunWebApp>
  <EnableRemoteAccess>true</EnableRemoteAccess>
  <EnableCaseSensitiveItemIds>true</EnableCaseSensitiveItemIds>
  <Metadata>
    <Tv>
      <ReleaseDateFormat>yyyy-MM-dd</ReleaseDateFormat>
      <SanitizeItemNames>false</SanitizeItemNames>
      <PreferredMetadataLanguage>en</PreferredMetadataLanguage>
      <MetadataCountryCode>US</MetadataCountryCode>
      <UseFileCreationTimeForDateAdded>false</UseFileCreationTimeForDateAdded>
    </Tv>
    <Movie>
      <ReleaseDateFormat>yyyy-MM-dd</ReleaseDateFormat>
      <SanitizeItemNames>false</SanitizeItemNames>
      <PreferredMetadataLanguage>en</PreferredMetadataLanguage>
      <MetadataCountryCode>US</MetadataCountryCode>
      <UseFileCreationTimeForDateAdded>false</UseFileCreationTimeForDateAdded>
    </Movie>
  </Metadata>
</ServerConfiguration>
